generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  username       String          @unique
  name           String
  password       String
  avatar         String?
  role           String          @default("USER")
  emailVerified  Boolean         @default(false)
  banned         Boolean         @default(false)
  banReason      String?
  bannedUntil    DateTime?
  bio            String?         @db.VarChar(200)
  socialLinks    String?         @db.Text
  customStatus   String?         @db.VarChar(100)
  statusEmoji    String?         @db.VarChar(10)
  statusType     String?         @default("online") @db.VarChar(20)
  privacyOnline  String          @default("everyone")
  privacyFriends String          @default("everyone")
  privacyEmail   Boolean         @default(false)
  notifySound    Boolean         @default(true)
  notifyPush     Boolean         @default(true)
  mutedGroups    String?         @db.Text
  mutedChannels  String?         @db.Text
  messages       Message[]
  channelMembers ChannelMember[]
  groupMembers   GroupMember[]
  ownedGroups    Group[]         @relation("GroupOwner")
  invitesCreated    Invite[]
  aiChats           AiChat[]
  friendsSent       Friendship[]   @relation("FriendshipSender")
  friendsReceived   Friendship[]   @relation("FriendshipReceiver")
  hostedGameRooms   GameRoom[]     @relation("GameHost")
  gamePlayers       GamePlayer[]
  gameInvitesSent   GameInvite[]   @relation("GameInviteSender")
  gameInvitesRecvd  GameInvite[]   @relation("GameInviteReceiver")
  reactions         Reaction[]
  badges            UserBadge[]
  sessions          UserSession[]
  dmConversations1  DirectConversation[] @relation("DMUser1")
  dmConversations2  DirectConversation[] @relation("DMUser2")
  directMessages    DirectMessage[]
  notifications     Notification[]
  channelMutes      ChannelMute[]
  polls             Poll[]          @relation("UserPolls")
  pollVotes         PollVote[]
  tasksCreated      ChannelTask[]   @relation("TaskCreator")
  tasksAssigned     ChannelTask[]   @relation("TaskAssignee")
  messageReads     MessageRead[]
  scheduledMsgs    ScheduledMessage[]
  avatarGlowEnabled Boolean         @default(false)
  avatarGlowColors  String?
  profileBanner     String?         @db.Text
  e2eePublicKey     String?         @db.Text
  tosAccepted       Boolean         @default(false)
  lastSeen          DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([email])
  @@index([username])
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      String   @default("register")
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
}

model Group {
  id          String        @id @default(cuid())
  name        String
  icon        String?
  description String        @default("")
  rules       String        @default("") @db.Text
  isMain      Boolean       @default(false)
  ownerId     String
  owner       User          @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  channels    Channel[]
  members     GroupMember[]
  invites     Invite[]
  roles       GroupRole[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model GroupMember {
  id            String              @id @default(cuid())
  userId        String
  groupId       String
  role          String              @default("MEMBER")
  rulesAccepted Boolean             @default(false)
  sortOrder     Int                 @default(0)
  muted         Boolean             @default(false)
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  group         Group               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  tags          GroupMemberRole[]
  joinedAt      DateTime            @default(now())

  @@unique([userId, groupId])
}

model Invite {
  id        String    @id @default(cuid())
  code      String    @unique
  groupId   String
  createdBy String
  maxUses   Int       @default(0)
  uses      Int       @default(0)
  expiresAt DateTime?
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator   User      @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}

model Channel {
  id             String               @id @default(cuid())
  name           String
  type           String               @default("TEXT")
  icon           String?
  groupId        String
  isRestricted   Boolean              @default(false)
  postAccess     String               @default("ALL")
  slowmode       Int                  @default(0)
  serviceId      String?
  parentId       String?
  sortOrder      Int                  @default(0)
  parent         Channel?             @relation("ChannelTree", fields: [parentId], references: [id], onDelete: SetNull)
  children       Channel[]            @relation("ChannelTree")
  group          Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  members        ChannelMember[]
  messages       Message[]
  polls          Poll[]
  tasks          ChannelTask[]
  allowedRoles   ChannelRoleAccess[]
  mutes          ChannelMute[]
  scheduledMsgs  ScheduledMessage[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([groupId])
  @@index([serviceId])
  @@index([parentId])
}

model ChannelMember {
  id        String   @id @default(cuid())
  userId    String
  channelId String
  role      String   @default("MEMBER")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())
  lastRead  DateTime @default(now())

  @@unique([userId, channelId])
}

model Message {
  id           String    @id @default(cuid())
  content      String
  userId       String
  channelId    String
  edited       Boolean   @default(false)
  editedAt     DateTime?
  deleted      Boolean   @default(false)
  pinned       Boolean   @default(false)
  pinnedBy     String?
  pinnedAt     DateTime?
  replyToId    String?
  replyTo      Message?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[] @relation("MessageReplies")
  threadId     String?
  threadParent Message?  @relation("MessageThreads", fields: [threadId], references: [id], onDelete: SetNull)
  threadReplies Message[] @relation("MessageThreads")
  threadCount  Int       @default(0)
  attachments  String?
  mentions     String?   @db.Text
  reactions    Reaction[]
  reads        MessageRead[]
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel      Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())

  @@index([channelId, createdAt])
  @@index([replyToId])
  @@index([threadId])
}

model Reaction {
  id        String   @id @default(cuid())
  emoji     String
  userId    String
  messageId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, messageId, emoji])
  @@index([messageId])
}

model DirectConversation {
  id        String          @id @default(cuid())
  user1Id   String
  user2Id   String
  user1     User            @relation("DMUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2     User            @relation("DMUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages  DirectMessage[]
  lastMessageAt DateTime?
  user1ReadAt   DateTime?
  user2ReadAt   DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
}

model DirectMessage {
  id             String             @id @default(cuid())
  content        String
  userId         String
  conversationId String
  edited         Boolean            @default(false)
  editedAt       DateTime?
  deleted        Boolean            @default(false)
  attachments    String?
  replyToId      String?
  encrypted      Boolean            @default(false)
  replyTo        DirectMessage?     @relation("DMReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies        DirectMessage[]    @relation("DMReply")
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now())

  @@index([conversationId, createdAt])
  @@index([replyToId])
}

model Badge {
  id          String      @id @default(cuid())
  name        String
  description String      @db.Text
  icon        String?
  imageUrl    String?
  rarity      String      @default("common")
  active      Boolean     @default(true)
  users       UserBadge[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedBy String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awardedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent String?
  ip        String?
  token     String   @unique
  active    Boolean  @default(true)
  lastUsed  DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model Article {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String   @db.Text
  category  String
  tags      String   @default("")
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          String  @id @default(cuid())
  title       String
  description String  @db.Text
  icon        String?
  order       Int     @default(0)
  active      Boolean @default(true)
}

// Custom roles (tags) for groups — no admin/mod powers, just labels
model GroupRole {
  id        String              @id @default(cuid())
  name      String
  color     String              @default("#808080")
  groupId   String
  group     Group               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  members   GroupMemberRole[]
  channels  ChannelRoleAccess[]
  createdAt DateTime            @default(now())

  @@unique([groupId, name])
  @@index([groupId])
}

// Many-to-many: which members have which tags
model GroupMemberRole {
  id        String      @id @default(cuid())
  memberId  String
  roleId    String
  member    GroupMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  role      GroupRole    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([memberId, roleId])
  @@index([roleId])
}

// Which roles can see a restricted channel
model ChannelRoleAccess {
  id        String    @id @default(cuid())
  channelId String
  roleId    String
  channel   Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  role      GroupRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([channelId, roleId])
  @@index([channelId])
}

model EcosystemItem {
  id          String  @id @default(cuid())
  title       String
  description String  @db.Text
  imageUrl    String?
  linkUrl     String?
  section     String
  order       Int     @default(0)
  active      Boolean @default(true)
}

model WindowConfig {
  id              String  @id @default(cuid())
  windowKey       String  @unique
  title           String
  subtitle        String  @default("")
  description     String  @default("")
  href            String  @default("")
  accentColor     String  @default("#ff4444")
  backgroundUrl   String?
  backgroundType  String  @default("gradient")
  gradientFrom    String  @default("#1a0000")
  gradientTo      String  @default("#0a0a0f")
  order           Int     @default(0)
  active          Boolean @default(true)
}

model SiteConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
}

model AiChat {
  id        String      @id @default(cuid())
  userId    String
  title     String      @default("Новый диалог")
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AiMessage[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
}

model Friendship {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  status     String   @default("PENDING")
  sender     User     @relation("FriendshipSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("FriendshipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([senderId, receiverId])
  @@index([receiverId])
}

model GameRoom {
  id          String       @id @default(cuid())
  name        String
  hostId      String
  host        User         @relation("GameHost", fields: [hostId], references: [id], onDelete: Cascade)
  status      String       @default("LOBBY")
  gameType    String       @default("velderan")
  maxPlayers  Int          @default(6)
  inviteCode  String       @unique
  gameState   String?      @db.Text
  players     GamePlayer[]
  invites     GameInvite[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model GamePlayer {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  faction   String?
  color     String?
  isReady   Boolean  @default(false)
  turnOrder Int      @default(0)
  room      GameRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@unique([roomId, userId])
  @@unique([roomId, faction])
}

model GameInvite {
  id         String   @id @default(cuid())
  roomId     String
  inviterId  String
  inviteeId  String
  status     String   @default("PENDING")
  room       GameRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  inviter    User     @relation("GameInviteSender", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee    User     @relation("GameInviteReceiver", fields: [inviteeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([roomId, inviteeId])
}

model AiMessage {
  id        String   @id @default(cuid())
  chatId    String
  role      String
  content   String   @db.Text
  chat      AiChat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([chatId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  username   String
  action     String
  target     String
  targetId   String?
  details    String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

model Poll {
  id         String       @id @default(cuid())
  channelId  String
  userId     String
  question   String
  anonymous  Boolean      @default(false)
  multiple   Boolean      @default(false)
  closed     Boolean      @default(false)
  channel    Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user       User         @relation("UserPolls", fields: [userId], references: [id], onDelete: Cascade)
  options    PollOption[]
  createdAt  DateTime     @default(now())

  @@index([channelId])
}

model PollOption {
  id      String     @id @default(cuid())
  pollId  String
  text    String
  poll    Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes   PollVote[]

  @@index([pollId])
}

model PollVote {
  id       String     @id @default(cuid())
  optionId String
  userId   String
  option   PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([optionId, userId])
}

model ChannelTask {
  id          String   @id @default(cuid())
  channelId   String
  creatorId   String
  assigneeId  String?
  title       String
  description String?
  status      String   @default("open")
  priority    String   @default("normal")
  dueDate     DateTime?
  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  creator     User     @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  assignee    User?    @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([channelId])
  @@index([assigneeId])
  @@index([status])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

model ChannelMute {
  id        String   @id @default(cuid())
  userId    String
  channelId String
  muted     Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([userId])
}

model MessageRead {
  id        String   @id @default(cuid())
  userId    String
  messageId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  readAt    DateTime @default(now())

  @@unique([userId, messageId])
  @@index([messageId])
}

model ScheduledMessage {
  id          String   @id @default(cuid())
  content     String
  userId      String
  channelId   String
  scheduledAt DateTime
  sent        Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([scheduledAt, sent])
  @@index([userId])
}
