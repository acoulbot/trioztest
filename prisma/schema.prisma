generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  username       String          @unique
  name           String
  password       String
  avatar         String?
  role           String          @default("USER")
  emailVerified  Boolean         @default(false)
  banned         Boolean         @default(false)
  banReason      String?
  bannedUntil    DateTime?
  messages       Message[]
  channelMembers ChannelMember[]
  groupMembers   GroupMember[]
  ownedGroups    Group[]         @relation("GroupOwner")
  invitesCreated    Invite[]
  aiChats           AiChat[]
  friendsSent       Friendship[]   @relation("FriendshipSender")
  friendsReceived   Friendship[]   @relation("FriendshipReceiver")
  hostedGameRooms   GameRoom[]     @relation("GameHost")
  gamePlayers       GamePlayer[]
  gameInvitesSent   GameInvite[]   @relation("GameInviteSender")
  gameInvitesRecvd  GameInvite[]   @relation("GameInviteReceiver")
  avatarGlowEnabled Boolean         @default(false)
  avatarGlowColors  String?
  lastSeen          DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([email])
  @@index([username])
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      String   @default("register")
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
}

model Group {
  id          String        @id @default(cuid())
  name        String
  icon        String?
  description String        @default("")
  ownerId     String
  owner       User          @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  channels    Channel[]
  members     GroupMember[]
  invites     Invite[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model GroupMember {
  id       String   @id @default(cuid())
  userId   String
  groupId  String
  role     String   @default("MEMBER")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([userId, groupId])
}

model Invite {
  id        String    @id @default(cuid())
  code      String    @unique
  groupId   String
  createdBy String
  maxUses   Int       @default(0)
  uses      Int       @default(0)
  expiresAt DateTime?
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator   User      @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}

model Channel {
  id        String          @id @default(cuid())
  name      String
  type      String          @default("TEXT")
  icon      String?
  groupId   String
  group     Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  members   ChannelMember[]
  messages  Message[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([groupId])
}

model ChannelMember {
  id        String   @id @default(cuid())
  userId    String
  channelId String
  role      String   @default("MEMBER")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())
  lastRead  DateTime @default(now())

  @@unique([userId, channelId])
}

model Message {
  id           String    @id @default(cuid())
  content      String
  userId       String
  channelId    String
  edited       Boolean   @default(false)
  editedAt     DateTime?
  deleted      Boolean   @default(false)
  attachments  String?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel      Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())

  @@index([channelId, createdAt])
}

model Article {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String   @db.Text
  category  String
  tags      String   @default("")
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          String  @id @default(cuid())
  title       String
  description String  @db.Text
  icon        String?
  order       Int     @default(0)
  active      Boolean @default(true)
}

model EcosystemItem {
  id          String  @id @default(cuid())
  title       String
  description String  @db.Text
  imageUrl    String?
  linkUrl     String?
  section     String
  order       Int     @default(0)
  active      Boolean @default(true)
}

model WindowConfig {
  id              String  @id @default(cuid())
  windowKey       String  @unique
  title           String
  subtitle        String  @default("")
  description     String  @default("")
  href            String  @default("")
  accentColor     String  @default("#ff4444")
  backgroundUrl   String?
  backgroundType  String  @default("gradient")
  gradientFrom    String  @default("#1a0000")
  gradientTo      String  @default("#0a0a0f")
  order           Int     @default(0)
  active          Boolean @default(true)
}

model SiteConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
}

model AiChat {
  id        String      @id @default(cuid())
  userId    String
  title     String      @default("Новый диалог")
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AiMessage[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
}

model Friendship {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  status     String   @default("PENDING")
  sender     User     @relation("FriendshipSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("FriendshipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([senderId, receiverId])
  @@index([receiverId])
}

model GameRoom {
  id          String       @id @default(cuid())
  name        String
  hostId      String
  host        User         @relation("GameHost", fields: [hostId], references: [id], onDelete: Cascade)
  status      String       @default("LOBBY")
  gameType    String       @default("velderan")
  maxPlayers  Int          @default(6)
  inviteCode  String       @unique
  players     GamePlayer[]
  invites     GameInvite[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model GamePlayer {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  faction   String?
  color     String?
  isReady   Boolean  @default(false)
  turnOrder Int      @default(0)
  room      GameRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@unique([roomId, userId])
  @@unique([roomId, faction])
}

model GameInvite {
  id         String   @id @default(cuid())
  roomId     String
  inviterId  String
  inviteeId  String
  status     String   @default("PENDING")
  room       GameRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  inviter    User     @relation("GameInviteSender", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee    User     @relation("GameInviteReceiver", fields: [inviteeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([roomId, inviteeId])
}

model AiMessage {
  id        String   @id @default(cuid())
  chatId    String
  role      String
  content   String   @db.Text
  chat      AiChat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([chatId])
}
