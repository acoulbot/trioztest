generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  username       String          @unique
  name           String
  password       String
  avatar         String?
  role           String          @default("USER")
  emailVerified  Boolean         @default(false)
  banned         Boolean         @default(false)
  banReason      String?
  bannedUntil    DateTime?
  bio            String?         @db.VarChar(200)
  socialLinks    String?         @db.Text
  customStatus   String?         @db.VarChar(100)
  statusEmoji    String?         @db.VarChar(10)
  privacyOnline  String          @default("everyone")
  privacyFriends String          @default("everyone")
  privacyEmail   Boolean         @default(false)
  notifySound    Boolean         @default(true)
  notifyPush     Boolean         @default(true)
  mutedGroups    String?         @db.Text
  mutedChannels  String?         @db.Text
  messages       Message[]
  channelMembers ChannelMember[]
  groupMembers   GroupMember[]
  ownedGroups    Group[]         @relation("GroupOwner")
  invitesCreated    Invite[]
  aiChats           AiChat[]
  friendsSent       Friendship[]   @relation("FriendshipSender")
  friendsReceived   Friendship[]   @relation("FriendshipReceiver")
  hostedGameRooms   GameRoom[]     @relation("GameHost")
  gamePlayers       GamePlayer[]
  gameInvitesSent   GameInvite[]   @relation("GameInviteSender")
  gameInvitesRecvd  GameInvite[]   @relation("GameInviteReceiver")
  reactions         Reaction[]
  badges            UserBadge[]
  sessions          UserSession[]
  dmConversations1  DirectConversation[] @relation("DMUser1")
  dmConversations2  DirectConversation[] @relation("DMUser2")
  directMessages    DirectMessage[]
  avatarGlowEnabled Boolean         @default(false)
  avatarGlowColors  String?
  lastSeen          DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([email])
  @@index([username])
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      String   @default("register")
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
}

model Group {
  id          String        @id @default(cuid())
  name        String
  icon        String?
  description String        @default("")
  rules       String        @default("") @db.Text
  ownerId     String
  owner       User          @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  channels    Channel[]
  members     GroupMember[]
  invites     Invite[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model GroupMember {
  id            String   @id @default(cuid())
  userId        String
  groupId       String
  role          String   @default("MEMBER")
  rulesAccepted Boolean  @default(false)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group         Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  joinedAt      DateTime @default(now())

  @@unique([userId, groupId])
}

model Invite {
  id        String    @id @default(cuid())
  code      String    @unique
  groupId   String
  createdBy String
  maxUses   Int       @default(0)
  uses      Int       @default(0)
  expiresAt DateTime?
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator   User      @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}

model Channel {
  id        String          @id @default(cuid())
  name      String
  type      String          @default("TEXT")
  icon      String?
  groupId   String
  group     Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  members   ChannelMember[]
  messages  Message[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([groupId])
}

model ChannelMember {
  id        String   @id @default(cuid())
  userId    String
  channelId String
  role      String   @default("MEMBER")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())
  lastRead  DateTime @default(now())

  @@unique([userId, channelId])
}

model Message {
  id           String    @id @default(cuid())
  content      String
  userId       String
  channelId    String
  edited       Boolean   @default(false)
  editedAt     DateTime?
  deleted      Boolean   @default(false)
  pinned       Boolean   @default(false)
  pinnedBy     String?
  pinnedAt     DateTime?
  replyToId    String?
  replyTo      Message?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[] @relation("MessageReplies")
  attachments  String?
  mentions     String?   @db.Text
  reactions    Reaction[]
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel      Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())

  @@index([channelId, createdAt])
  @@index([replyToId])
}

model Reaction {
  id        String   @id @default(cuid())
  emoji     String
  userId    String
  messageId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, messageId, emoji])
  @@index([messageId])
}

model DirectConversation {
  id        String          @id @default(cuid())
  user1Id   String
  user2Id   String
  user1     User            @relation("DMUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2     User            @relation("DMUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages  DirectMessage[]
  lastMessageAt DateTime?  
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
}

model DirectMessage {
  id             String             @id @default(cuid())
  content        String
  userId         String
  conversationId String
  edited         Boolean            @default(false)
  editedAt       DateTime?
  deleted        Boolean            @default(false)
  attachments    String?
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now())

  @@index([conversationId, createdAt])
}

model Badge {
  id          String      @id @default(cuid())
  name        String
  description String      @db.Text
  icon        String?
  imageUrl    String?
  rarity      String      @default("common")
  active      Boolean     @default(true)
  users       UserBadge[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedBy String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awardedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent String?
  ip        String?
  token     String   @unique
  active    Boolean  @default(true)
  lastUsed  DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model Article {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String   @db.Text
  category  String
  tags      String   @default("")
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          String  @id @default(cuid())
  title       String
  description String  @db.Text
  icon        String?
  order       Int     @default(0)
  active      Boolean @default(true)
}

model EcosystemItem {
  id          String  @id @default(cuid())
  title       String
  description String  @db.Text
  imageUrl    String?
  linkUrl     String?
  section     String
  order       Int     @default(0)
  active      Boolean @default(true)
}

model WindowConfig {
  id              String  @id @default(cuid())
  windowKey       String  @unique
  title           String
  subtitle        String  @default("")
  description     String  @default("")
  href            String  @default("")
  accentColor     String  @default("#ff4444")
  backgroundUrl   String?
  backgroundType  String  @default("gradient")
  gradientFrom    String  @default("#1a0000")
  gradientTo      String  @default("#0a0a0f")
  order           Int     @default(0)
  active          Boolean @default(true)
}

model SiteConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
}

model AiChat {
  id        String      @id @default(cuid())
  userId    String
  title     String      @default("Новый диалог")
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AiMessage[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
}

model Friendship {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  status     String   @default("PENDING")
  sender     User     @relation("FriendshipSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("FriendshipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([senderId, receiverId])
  @@index([receiverId])
}

model GameRoom {
  id          String       @id @default(cuid())
  name        String
  hostId      String
  host        User         @relation("GameHost", fields: [hostId], references: [id], onDelete: Cascade)
  status      String       @default("LOBBY")
  gameType    String       @default("velderan")
  maxPlayers  Int          @default(6)
  inviteCode  String       @unique
  players     GamePlayer[]
  invites     GameInvite[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model GamePlayer {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  faction   String?
  color     String?
  isReady   Boolean  @default(false)
  turnOrder Int      @default(0)
  room      GameRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@unique([roomId, userId])
  @@unique([roomId, faction])
}

model GameInvite {
  id         String   @id @default(cuid())
  roomId     String
  inviterId  String
  inviteeId  String
  status     String   @default("PENDING")
  room       GameRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  inviter    User     @relation("GameInviteSender", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee    User     @relation("GameInviteReceiver", fields: [inviteeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([roomId, inviteeId])
}

model AiMessage {
  id        String   @id @default(cuid())
  chatId    String
  role      String
  content   String   @db.Text
  chat      AiChat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([chatId])
}
